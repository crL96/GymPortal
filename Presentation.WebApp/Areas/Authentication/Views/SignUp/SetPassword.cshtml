@using Presentation.WebApp.Areas.Authentication.Models
@model SetPasswordForm
@{
    ViewData["Title"] = "Set Password";
}

<section class="section__auth">
    <div class="title">
        <h1>Set Your Password</h1>
        <p>Set a strong password to protect your account. For security reasons, your password must be at least 8
            characters long and include uppercase and lowercase letters, numbers, and special characters.
        </p>
    </div>
        
    <hr />

    <form id="setPasswordForm" method="post" asp-area="Authentication" asp-controller="SignUp" asp-action="SetPassword"
          novalidate>
        @Html.AntiForgeryToken()

        <div class="form-group">
            <label class="form-label" asp-for="Password"></label>
            <input class="form-input" asp-for="Password" />
            <span class="field-validation" asp-validation-for="Password"></span>
        </div>

        <div class="form-group">
            <label class="form-label" asp-for="ConfirmPassword"></label>
            <input class="form-input" asp-for="ConfirmPassword" />
            <span class="field-validation" asp-validation-for="ConfirmPassword"></span>
        </div>

        <button class="btn" type="submit">Continue</button>
        
        <div class="form-errormessage">
            <span class="field-validation-error" asp-validation-for="ErrorMessage"></span>
        </div>

        <div asp-validation-summary="ModelOnly"></div>
        <input type="hidden" name="returnUrl" value="@ViewBag.ReturnUrl" />
    </form>

</section>
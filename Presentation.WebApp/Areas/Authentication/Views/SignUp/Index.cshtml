@using Presentation.WebApp.Areas.Authentication.Models
@model SetEmailForm
@{
    ViewData["Title"] = "Become a Member";
}

<section class="section__auth">
    <div class="title">
        <h1>Become a Member</h1>
        <p>Sign up to continue your fitness journey with full access to your customized program, training history, and
            progress tracking. Stay consistent, monitor your development, and keep moving forward with the structure and
            support built into your account.
        </p>
    </div>
        
    <hr />

    <form id="setEmailForm" method="post" asp-area="Authentication" asp-controller="SignUp" asp-action="Index"
          novalidate>
        @Html.AntiForgeryToken()

        <div data-type="email" class="form-group">
            <label class="form-label" asp-for="Email"></label>
            <input class="form-input" asp-for="Email" />
            <span class="field-validation" asp-validation-for="Email"></span>
        </div>
        
        <div data-type="terms" class="form-group checkbox">
            <div class="form-checkbox-validation">
                <label class="form-checkbox-label">
                    <input class="form-checkbox-input" asp-for="TermsAndConditions" />
                    <span class="form-checkbox-checkmark"></span>
                    <label class="checkbox-label" asp-for="TermsAndConditions"></label>
                </label>
                <span class="field-validation" asp-validation-for="TermsAndConditions"></span>
            </div>
        </div>

        <button data-type="submit" class="btn" type="submit">Continue</button>

        <div data-type="error" class="form-errormessage">
            <span class="field-validation" asp-validation-for="ErrorMessage"></span>
        </div>

        <div asp-validation-summary="ModelOnly"></div>

        <input type="hidden" name="returnUrl" value="@ViewBag.ReturnUrl" />
    </form>

</section>


@section Scripts {
    <partial name="Partials/Globals/_ValidationScripts" />

    <script>
        $(function () {
            setupCheckboxValidation({
                formId: "#setEmailForm",
                checkboxId: "#TermsAndConditions",
                message: "Accepting the user terms & conditions is required"
            });
        });
    </script>
}
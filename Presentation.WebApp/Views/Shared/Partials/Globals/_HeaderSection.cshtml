<section class="header-section">
    <a class="logotype" href="/"><img src="~/images/logotype.png" alt="CoreFitness"></a>
    <nav class="main-menu">
        <ul class="menu">
            <li class="menu-item">
                <a class="menu-item-link" asp-action="Index" asp-controller="FitnessCenters">Fitness Centers</a>
            </li>
            <li class="menu-item">
                <a class="menu-item-link" asp-action="Index" asp-controller="Memberships">Memberships</a>
            </li>
            <li class="menu-item menu-dropdown">
                <a class="menu-item-link" asp-action="Index" asp-controller="Training">Training</a>
            </li>
            <li class="menu-item">
                <a class="menu-item-link" asp-action="Index" asp-controller="Support">Customer Service</a>
            </li>
        </ul>
    </nav>
    <nav class="account-menu">
        <ul class="menu">
            @if (User.Identity?.IsAuthenticated == true)
            {
                <li class="menu-item">
                    <a class="menu-item-link" href="/">
                        Our Classes
                    </a>
                </li>
                <li class="menu-item">
                    <a class="btn btn-accent" asp-area="Account" asp-action="Index" asp-controller="Home">My Account</a>
                </li>
            }
            else
            {
                <li class="menu-item">
                    <a class="menu-item-link" asp-area="Authentication" asp-action="Index" asp-controller="SignUp">
                        Become Member
                    </a>
                </li>
                <li class="menu-item">
                    <a class="btn btn-accent" asp-area="Authentication" asp-action="Index" asp-controller="SignIn">
                        Sign In
                    </a>
                </li>
            }
        </ul>

    </nav>
    <button id="mobile-menu-button" data-target="#mobile-menu-flyout" class="mobile-btn btn-accent"></button>
</section>
